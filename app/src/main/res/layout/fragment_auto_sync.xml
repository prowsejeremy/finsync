<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/autoSyncCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/surface_1"
        app:strokeWidth="0dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto-sync Schedule"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="@font/hk_extrabold"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose how often Finsync should automatically sync your music library in the background. You can also trigger a manual sync from the home screen at any time."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/hk_regular"
                android:paddingBottom="12dp" />

            <RadioGroup
                android:id="@+id/radioGroupAutoSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rbDisabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Disabled"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/hk_regular"
                    android:buttonTint="@color/selector_accent"
                    android:paddingVertical="10dp" />

                <RadioButton
                    android:id="@+id/rbEvery1h"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every 1 hour"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/hk_regular"
                    android:buttonTint="@color/selector_accent"
                    android:paddingVertical="10dp" />

                <RadioButton
                    android:id="@+id/rbEvery6h"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every 6 hours"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/hk_regular"
                    android:buttonTint="@color/selector_accent"
                    android:paddingVertical="10dp" />

                <RadioButton
                    android:id="@+id/rbEvery12h"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every 12 hours"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/hk_regular"
                    android:buttonTint="@color/selector_accent"
                    android:paddingVertical="10dp" />

                <RadioButton
                    android:id="@+id/rbEvery24h"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every 24 hours"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/hk_regular"
                    android:buttonTint="@color/selector_accent"
                    android:paddingVertical="10dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/muted"
                android:alpha="0.35"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textColor="@color/muted"
                    android:textSize="15sp"
                    android:fontFamily="@font/hk_regular"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/btnApply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apply"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/hk_extrabold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>