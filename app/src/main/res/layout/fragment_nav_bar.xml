<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/navBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/surface_1"
    android:paddingTop="12dp"
    android:paddingBottom="20dp"
    android:paddingHorizontal="48dp">

    <LinearLayout
        android:id="@+id/tabHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <FrameLayout
            android:id="@+id/tabHomePill"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp">

            <ImageView
                android:id="@+id/tabHomeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home"
                app:tint="@color/muted" />

        </FrameLayout>

        <TextView
            android:id="@+id/tabHomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:fontFamily="@font/hk_regular" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabDownloads"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <FrameLayout
            android:id="@+id/tabDownloadsPill"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp">

            <ImageView
                android:id="@+id/tabDownloadsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_download"
                app:tint="@color/muted" />

        </FrameLayout>

        <TextView
            android:id="@+id/tabDownloadsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Downloads"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:fontFamily="@font/hk_regular" />

    </LinearLayout>

</LinearLayout>
