<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingHorizontal="24dp"
    android:paddingBottom="40dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="28dp"
        android:background="@color/muted" />

    <!-- Server icon + name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="@color/surface_2"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_server"
                app:tint="@color/text_primary" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvSheetServerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Name"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/hk_extrabold" />

    </LinearLayout>

    <!-- URL row with green status dot -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <View
            android:id="@+id/serverStatusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/circle_accent_green" />

        <TextView
            android:id="@+id/tvSheetServerUrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="https://jellyfin.jpd.com"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:fontFamily="@font/hk_regular"
            android:ellipsize="end"
            android:singleLine="true" />

    </LinearLayout>

    <!-- Log out button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Log out"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:fontFamily="@font/hk_regular"
        android:backgroundTint="@color/surface_2"
        app:cornerRadius="26dp" />

</LinearLayout>